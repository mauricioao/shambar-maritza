---
const zonas = [
  { name: 'Lince', desc: 'Zona principal' },
  { name: 'Jesús María', desc: 'Zona este' },
  { name: 'San Isidro', desc: 'Zona norte' },
  { name: 'Cercado', desc: 'Zona sur' },
];
---

<section class="zonas" id="zonas">
  <div class="zonas-inner">
    <div class="zonas-header">
      <span class="zonas-label">Delivery</span>
      <h2>Zonas de reparto</h2>
    </div>

    <div class="zonas-content">
      <!-- Mapa minimalista - Lince centro, Jesús María derecha -->
      <div class="zonas-map">
        <svg viewBox="0 0 300 200" class="map-svg">
          <rect width="300" height="200" fill="#141210" rx="8"/>
          
          <!-- Grid -->
          <g stroke="rgba(255,255,255,0.03)" stroke-width="1">
            <line x1="0" y1="50" x2="300" y2="50"/>
            <line x1="0" y1="100" x2="300" y2="100"/>
            <line x1="0" y1="150" x2="300" y2="150"/>
            <line x1="75" y1="0" x2="75" y2="200"/>
            <line x1="150" y1="0" x2="150" y2="200"/>
            <line x1="225" y1="0" x2="225" y2="200"/>
          </g>
          
          <!-- Lince (centro) -->
          <circle cx="130" cy="100" r="38" fill="rgba(201, 141, 75, 0.15)" stroke="#C98D4B" stroke-width="1.5"/>
          <text x="130" y="105" text-anchor="middle" fill="#FDFBF7" font-size="10" font-family="var(--font-body)">Lince</text>
          
          <!-- Jesús María (a la derecha, intersectando con Lince) -->
          <circle cx="195" cy="100" r="32" fill="rgba(201, 141, 75, 0.1)" stroke="#C98D4B" stroke-width="1"/>
          <text x="195" y="105" text-anchor="middle" fill="#A9A194" font-size="8" font-family="var(--font-body)">Jesús María</text>
          
          <!-- San Isidro (arriba) -->
          <circle cx="130" cy="45" r="25" fill="rgba(201, 141, 75, 0.1)" stroke="#C98D4B" stroke-width="1"/>
          <text x="130" y="50" text-anchor="middle" fill="#A9A194" font-size="8" font-family="var(--font-body)">San Isidro</text>
          
          <!-- Cercado (abajo) -->
          <circle cx="130" cy="160" r="28" fill="rgba(201, 141, 75, 0.1)" stroke="#C98D4B" stroke-width="1"/>
          <text x="130" y="165" text-anchor="middle" fill="#A9A194" font-size="8" font-family="var(--font-body)">Cercado</text>
        </svg>
      </div>

      <!-- Lista -->
      <div class="zonas-list">
        {zonas.map((zona) => (
          <div class="zona-item">
            <span class="zona-dot"></span>
            <div class="zona-info">
              <span class="zona-name">{zona.name}</span>
              <span class="zona-desc">{zona.desc}</span>
            </div>
          </div>
        ))}
        <p class="zonas-note">Sin costo adicional de delivery</p>
      </div>
    </div>
  </div>
</section>

<style>
  .zonas {
    padding: var(--space-3xl) var(--space-lg);
    background: var(--color-bg-secondary);
  }

  .zonas-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .zonas-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .zonas-label {
    display: block;
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .zonas-header h2 {
    font-size: 1.75rem;
    font-weight: 400;
  }

  .zonas-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  /* Mapa */
  .zonas-map {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
  }

  .map-svg {
    width: 100%;
    height: auto;
  }

  /* Lista */
  .zonas-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .zona-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .zona-dot {
    width: 8px;
    height: 8px;
    background: var(--color-accent);
    border-radius: 50%;
  }

  .zona-info {
    display: flex;
    flex-direction: column;
  }

  .zona-name {
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  .zona-desc {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .zonas-note {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    margin-top: var(--space-sm);
  }

  @media (max-width: 768px) {
    .zonas-content {
      grid-template-columns: 1fr;
    }
  }
</style>