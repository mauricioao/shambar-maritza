---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import ProximaFecha from '../components/ProximaFecha.astro';
import AboutCarousel from '../components/AboutCarousel.astro';
import DecoVideo from '../components/DecoVideo.astro';
import Zonas from '../components/Zonas.astro';
import Horarios from '../components/Horarios.astro';
import Ordenar from '../components/Ordenar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Shambar Lince | Tradición Limeña">
