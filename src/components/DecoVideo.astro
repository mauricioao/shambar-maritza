---

<div class="deco-section">
  <div class="deco-bg">
    <video autoplay muted loop playsinline class="deco-video">
      <source src="/assets/cancha_serrana.mp4" type="video/mp4" />
    </video>
    <div class="deco-overlay"></div>
  </div>
  
  <div class="deco-content">
    <span class="deco-label">Tradición en cada detalle</span>
  </div>
</div>

<style>
  .deco-section {
    position: relative;
    height: 240px;
    overflow: hidden;
  }

  .deco-bg {
    position: absolute;
    inset: 0;
  }

  .deco-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.05);
    animation: subtleMove 25s ease-in-out infinite alternate;
  }

  @keyframes subtleMove {
    0% { transform: scale(1.05) translateX(0); }
    100% { transform: scale(1.1) translateX(-3%); }
  }

  .deco-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(12, 10, 9, 0.85) 0%,
      rgba(12, 10, 9, 0.5) 50%,
      rgba(12, 10, 9, 0.85) 100%
    );
  }

  .deco-content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .deco-label {
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .deco-section {
      height: 180px;
    }
  }
</style>