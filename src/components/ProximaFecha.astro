---
// Fechas de reparto
const fechasReparto = [
  { fecha: '2026-04-06', nombre: 'Domingo' },
  { fecha: '2026-04-13', nombre: 'Domingo' },
  { fecha: '2026-04-20', nombre: 'Domingo' },
  { fecha: '2026-04-27', nombre: 'Domingo' },
  { fecha: '2026-05-03', nombre: 'Domingo' },
  { fecha: '2026-05-10', nombre: 'Domingo' },
  { fecha: '2026-05-17', nombre: 'Domingo' },
  { fecha: '2026-05-24', nombre: 'Domingo' },
  { fecha: '2026-05-31', nombre: 'Domingo' },
];

const hoy = new Date();
const hoyStr = hoy.toISOString().split('T')[0];

const fechasFuturas = fechasReparto.filter(f => f.fecha >= hoyStr);
const proximaFecha = fechasFuturas[0];

const fechaObj = proximaFecha ? new Date(proximaFecha.fecha + 'T00:00:00') : null;
const mes = fechaObj ? fechaObj.toLocaleDateString('es-PE', { month: 'long' }).toUpperCase() : '';
const dia = fechaObj ? fechaObj.getDate() : '';

const primerDiaMes = new Date(fechaObj.getFullYear(), fechaObj.getMonth(), 1);
const ultimoDiaMes = new Date(fechaObj.getFullYear(), fechaObj.getMonth() + 1, 0);
const diasEnMes = ultimoDiaMes.getDate();
const diaSemanaInicio = primerDiaMes.getDay();

const diasDelMes = [];
for (let i = 1; i <= diasEnMes; i++) {
  const fechaStr = `${fechaObj.getFullYear()}-${String(fechaObj.getMonth() + 1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
  const esReparto = fechasReparto.some(f => f.fecha === fechaStr);
  const esPasado = fechaStr < hoyStr;
  const esProxima = fechaStr === proximaFecha?.fecha;
  
  diasDelMes.push({ dia: i, fecha: fechaStr, esReparto, esPasado, esProxima });
}
---

<section class="proxima-fecha" id="fechas">
  <div class="pf-container">
    <div class="pf-text">
      <span class="pf-label">Próxima entrega</span>
      
      {proximaFecha ? (
        <div class="pf-fecha">
          <span class="pf-dia">{dia}</span>
          <div class="pf-details">
            <span class="pf-nombre">{proximaFecha.nombre}</span>
            <span class="pf-mes">{mes}</span>
          </div>
        </div>
      ) : (
        <p class="pf-vacio">Sin fechas programadas</p>
      )}
      
      <p class="pf-note">Entregas únicamente en fechas indicadas</p>
    </div>

    <div class="pf-calendar">
      <div class="cal-header">
        <span class="cal-month">{mes}</span>
        <span class="cal-year">{fechaObj?.getFullYear()}</span>
      </div>
      
      <div class="cal-weekdays">
        <span>D</span><span>L</span><span>M</span><span>X</span><span>J</span><span>V</span><span>S</span>
      </div>
      
      <div class="cal-days">
        {Array(diaSemanaInicio).fill(null).map(() => (
          <span class="cal-day empty"></span>
        ))}
        
        {diasDelMes.map((d) => (
          <span 
            class:list={[
              'cal-day',
              d.esReparto && !d.esPasado && 'future',
              d.esPasado && 'past',
              d.esProxima && 'next'
            ]}
          >
            {d.dia}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .proxima-fecha {
    padding: var(--space-2xl) var(--space-lg);
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .pf-container {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: var(--space-2xl);
  }

  /* Text */
  .pf-text {
    flex: 1;
  }

  .pf-label {
    display: block;
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-sm);
  }

  .pf-fecha {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .pf-dia {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 400;
    color: var(--color-accent);
    line-height: 1;
  }

  .pf-details {
    display: flex;
    flex-direction: column;
  }

  .pf-nombre {
    font-size: 1rem;
    color: var(--color-text);
  }

  .pf-mes {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
  }

  .pf-note {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .pf-vacio {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
  }

  /* Calendar */
  .pf-calendar {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
    min-width: 180px;
  }

  .cal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: var(--space-sm);
    margin-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .cal-month {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  .cal-year {
    font-size: 0.625rem;
    color: var(--color-text-tertiary);
  }

  .cal-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
    margin-bottom: var(--space-xs);
  }

  .cal-weekdays span {
    font-size: 0.5625rem;
    color: var(--color-text-tertiary);
    text-align: center;
  }

  .cal-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }

  .cal-day {
    font-size: 0.625rem;
    color: var(--color-text-tertiary);
    text-align: center;
    padding: 4px;
    border-radius: 50%;
  }

  .cal-day.empty {
    background: none;
  }

  .cal-day.future {
    color: var(--color-text-secondary);
  }

  .cal-day.past {
    color: var(--color-text-tertiary);
    opacity: 0.4;
  }

  .cal-day.next {
    background: var(--color-accent);
    color: var(--color-bg-primary);
    font-weight: 500;
  }

  @media (max-width: 600px) {
    .pf-container {
      flex-direction: column;
      text-align: center;
    }

    .pf-fecha {
      justify-content: center;
    }
  }
</style>