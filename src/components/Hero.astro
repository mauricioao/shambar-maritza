---
---

<section class="hero">
  <div class="hero-bg">
    <video autoplay muted loop playsinline poster="/assets/shambar_01.jpeg">
      <source src="/assets/shambar_video_01.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <div class="hero-inner">
      <div class="hero-main">
        <p class="hero-label">Tradición limeña</p>
        
        <h1 class="hero-title">
          <span class="title-line">Shambar</span>
          <span class="title-accent">Lince</span>
        </h1>
        
        <p class="hero-description">
          El plato icono de Lima, preparado con los ingredientes más frescos 
          y la receta que ha pasado de generación en generación.
        </p>
        
        <a href="#ordenar" class="hero-cta">
          <span>Hacer pedido</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <div class="hero-meta">
        <div class="meta-item">
          <span class="meta-label">Delivery</span>
          <span class="meta-value">Lince, San Isidro, Jesús María</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Horario</span>
          <span class="meta-value">12:00 – 15:00</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Contacto</span>
          <span class="meta-value">918 380 045</span>
        </div>
      </div>
    </div>
  </div>

  <a href="#fechas" class="hero-scroll">
    <span>Descubrir</span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Background */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(12, 10, 9, 0.4) 0%,
      rgba(12, 10, 9, 0.7) 50%,
      rgba(12, 10, 9, 0.9) 100%
    );
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1000px;
    padding: 120px var(--space-lg) var(--space-lg);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
  }

  .hero-main {
    max-width: 600px;
  }

  .hero-label {
    font-family: var(--font-accent);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .hero-title {
    margin-bottom: var(--space-lg);
  }

  .title-line {
    display: block;
    font-size: clamp(3.5rem, 12vw, 7rem);
    font-weight: 400;
    color: var(--color-text);
    line-height: 1;
  }

  .title-accent {
    display: block;
    font-size: clamp(3.5rem, 12vw, 7rem);
    font-weight: 400;
    color: var(--color-accent);
    line-height: 1;
    font-style: italic;
  }

  .hero-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xl);
    max-width: 480px;
  }

  /* CTA */
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--color-accent);
    color: var(--color-bg-primary);
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.25s var(--ease-smooth);
  }

  .hero-cta:hover {
    background: var(--color-accent-light);
    gap: var(--space-md);
  }

  /* Meta */
  .hero-meta {
    display: flex;
    gap: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .meta-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }

  .meta-value {
    font-size: 0.875rem;
    color: var(--color-text);
  }

  /* Scroll */
  .hero-scroll {
    position: absolute;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    transition: color 0.2s;
  }

  .hero-scroll:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .hero-meta {
      flex-direction: column;
      gap: var(--space-md);
    }

    .hero-description {
      font-size: 1rem;
    }
  }
</style>